      <column caption='Total Production' datatype='real' name='[Calculation_0361781473431552]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[S_Prod_Tot] + [M_Prod_Tot]' />
      </column>
      <column caption='Yield per Capita' datatype='real' name='[Calculation_0361781473562625]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0361781473431552] / [POP]' />
      </column>
      <column caption='Yield' datatype='real' name='[Calculation_0361781482479618]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0361781473431552]) / SUM([Area])' />
      </column>
      <column caption='Yield Score' datatype='real' name='[Calculation_0361781482782723]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='( WINDOW_AVG([Calculation_0361781482479618]) - WINDOW_MIN(WINDOW_AVG([Calculation_0361781482479618])) )&#13;&#10;/&#13;&#10;( WINDOW_MAX(WINDOW_AVG([Calculation_0361781482479618])) - WINDOW_MIN(WINDOW_AVG([Calculation_0361781482479618])) )'>
